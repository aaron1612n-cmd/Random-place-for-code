<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
  <title>throw circle</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      background: black;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
      overflow: hidden;
      touch-action: none;
    }
    canvas { display: block; width: 100%; height: 100%; background: black; }
    #speedometer {
      position: absolute;
      bottom: 30px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 10;
      font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
      font-size: 13px;
      font-weight: 400;
      letter-spacing: 1.5px;
      color: rgba(255, 255, 255, 0.45);
      display: flex;
      align-items: center;
      gap: 8px;
      pointer-events: none;
      user-select: none;
      -webkit-user-select: none;
    }
    #speedometer .val { color: rgba(255, 255, 255, 0.8); font-weight: 500; min-width: 52px; text-align: right; }
    #speedometer .unit { font-size: 10px; color: rgba(255, 255, 255, 0.3); }
    #speedometer .bar-wrap { width: 80px; height: 2px; background: rgba(255, 255, 255, 0.08); border-radius: 1px; overflow: hidden; }
    #speedometer .bar-fill { height: 100%; background: rgba(255, 255, 255, 0.5); border-radius: 1px; transition: width 0.08s linear; }
    #speedometer .peak { color: rgba(255, 180, 100, 0.5); font-size: 10px; letter-spacing: 0.5px; }
    #speedometer .peak-val { color: rgba(255, 180, 100, 0.7); font-weight: 500; }
    #minimap {
      position: absolute;
      top: 16px; left: 16px;
      z-index: 10;
      width: 100px; height: 75px;
      border: 1px solid rgba(255, 255, 255, 0.2);
      border-radius: 4px;
      background: rgba(0, 0, 0, 0.5);
      pointer-events: none;
      user-select: none;
      -webkit-user-select: none;
    }
    #minimap canvas { width: 100%; height: 100%; background: transparent; }
  </style>
</head>
<body>
  <canvas id="c"></canvas>
  <div id="minimap"><canvas id="minimap-canvas"></canvas></div>
  <div id="speedometer">
    <span class="val" id="speed-val">0</span>
    <span class="unit">px/s</span>
    <div class="bar-wrap"><div class="bar-fill" id="speed-bar" style="width: 0%"></div></div>
    <span class="peak">PEAK <span class="peak-val" id="peak-val">0</span></span>
  </div>

  <script>
    (function() {
      const canvas = document.getElementById('c');
      const ctx = canvas.getContext('2d');
      const minimapCanvas = document.getElementById('minimap-canvas');
      const minimapCtx = minimapCanvas.getContext('2d');

      const WORLD_W = 4000;
      const WORLD_H = 2500;
      const RADIUS = 32;
      const GRAVITY = 980;
      const BOUNCE_DAMP = 0.72;
      const GROUND_FRICTION = 0.94;
      const LATENCY_BUFFER_SIZE = 8;
      const PORTAL_WIDTH = RADIUS * 2;
      const ROLLING_TORQUE = 25;
      const SPIN_FRICTION = 0.97;
      const GROUND_SPIN_FRICTION = 0.92;
      const THROW_SCALE = 0.55;
      const AFTERIMAGE_COUNT = 12;
      const AFTERIMAGE_SPACING = 2;
      const SPEED_LINE_COUNT = 16;
      const SPEED_LINE_LENGTH = 18;
      const SPEED_LINE_THRESHOLD = 400;
      const CAMERA_BASE_SPEED = 0.06;
      const CAMERA_SPEED_FACTOR = 0.00004;

      let cx = WORLD_W / 2, cy = WORLD_H / 2;
      let vx = 0, vy = 0;
      let angle = 0, angularVelocity = 0;
      let afterimages = [];
      let prevPositions = [];

      let camera = { x: WORLD_W / 2, y: WORLD_H / 2, zoom: 1.0, targetZoom: 1.0, minZoom: 0.4, maxZoom: 3.0 };
      let visualCamX = WORLD_W / 2;

      let dragging = false;
      let dragStartX = 0, dragStartY = 0;
      let circleStartX = 0, circleStartY = 0;
      let prevX = 0, prevY = 0;
      let prevTime = 0;
      let velocityBuffer = [];

      let panning = false;
      let panStartX = 0, panStartY = 0;
      let camStartX = 0, camStartY = 0;
      let pinching = false;
      let pinchStartDist = 0;
      let pinchStartZoom = 1.0;

      let lastTimestamp = 0;
      let animationId = null;

      const speedVal = document.getElementById('speed-val');
      const speedBar = document.getElementById('speed-bar');
      const peakVal = document.getElementById('peak-val');
      let displayedSpeed = 0;
      let peakSpeed = 0;

      function updateSpeedometer(speed) {
        displayedSpeed += (speed - displayedSpeed) * 0.3;
        const display = Math.round(displayedSpeed);
        speedVal.textContent = display;
        if (display > peakSpeed) { peakSpeed = display; peakVal.textContent = peakSpeed; }
        const maxForBar = 35000;
        const pct = Math.min((displayedSpeed / maxForBar) * 100, 100);
        speedBar.style.width = pct + '%';
        if (displayedSpeed < 2000) speedBar.style.background = 'rgba(255, 255, 255, 0.3)';
        else if (displayedSpeed < 8000) speedBar.style.background = 'rgba(255, 255, 255, 0.5)';
        else if (displayedSpeed < 20000) speedBar.style.background = 'rgba(255, 200, 130, 0.65)';
        else speedBar.style.background = 'rgba(255, 100, 60, 0.85)';
      }

      function worldToScreen(wx, wy) {
        let dx = wx - visualCamX;
        if (dx > WORLD_W / 2) dx -= WORLD_W;
        if (dx < -WORLD_W / 2) dx += WORLD_W;
        return {
          x: dx * camera.zoom + canvas.width / 2,
          y: (wy - camera.y) * camera.zoom + canvas.height / 2
        };
      }

      function screenToWorld(sx, sy) {
        return {
          x: (sx - canvas.width / 2) / camera.zoom + visualCamX,
          y: (sy - canvas.height / 2) / camera.zoom + camera.y
        };
      }

      function clampCircleY(y) {
        return Math.min(WORLD_H - RADIUS, Math.max(RADIUS, y));
      }

      function wrapX(x) {
        const w = WORLD_W;
        if (x < -RADIUS) return x + w;
        if (x > w + RADIUS) return x - w;
        return x;
      }

      function resizeCanvas() {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
        minimapCanvas.width = 100;
        minimapCanvas.height = 75;
      }

      function updateCamera() {
        camera.zoom += (camera.targetZoom - camera.zoom) * 0.15;
        if (Math.abs(camera.zoom - camera.targetZoom) < 0.001) camera.zoom = camera.targetZoom;

        // Speed-based follow — faster ball = faster camera
        const speed = Math.sqrt(vx * vx + vy * vy);
        const followSpeed = CAMERA_BASE_SPEED + speed * CAMERA_SPEED_FACTOR;
        const clampedFollow = Math.min(followSpeed, 0.95); // cap at 0.95 to avoid overshoot

        // Y follow
        camera.y += (cy - camera.y) * clampedFollow;

        // X follow with wrap awareness
        let diff = cx - visualCamX;
        if (diff > WORLD_W / 2) diff -= WORLD_W;
        if (diff < -WORLD_W / 2) diff += WORLD_W;
        visualCamX += diff * clampedFollow;
        while (visualCamX < 0) visualCamX += WORLD_W;
        while (visualCamX > WORLD_W) visualCamX -= WORLD_W;

        camera.x = visualCamX;
      }

      function getSpeedColor(speed) {
        const maxSpeed = 3000;
        const t = Math.min(speed / maxSpeed, 1.0);
        if (t < 0.33) {
          const s = t / 0.33;
          return `rgb(${Math.floor(136+(68-136)*s)},${Math.floor(136+(136-136)*s)},${Math.floor(136+(204-136)*s)})`;
        } else if (t < 0.66) {
          const s = (t-0.33)/0.33;
          return `rgb(${Math.floor(68+(255-68)*s)},${Math.floor(136+(136-136)*s)},${Math.floor(204+(68-204)*s)})`;
        } else {
          const s = (t-0.66)/0.34;
          return `rgb(${Math.floor(255+(255-255)*s)},${Math.floor(136+(51-136)*s)},${Math.floor(68+(51-68)*s)})`;
        }
      }

      function updateAfterimages() {
        const speed = Math.sqrt(vx*vx+vy*vy);
        if (speed < 50 || dragging) {
          for (let i = afterimages.length-1; i >= 0; i--) {
            afterimages[i].life -= 0.05;
            if (afterimages[i].life <= 0) afterimages.splice(i,1);
          }
          prevPositions = [];
          return;
        }
        prevPositions.push({ x: cx, y: cy, angle, speed });
        if (prevPositions.length > AFTERIMAGE_COUNT * AFTERIMAGE_SPACING) prevPositions.shift();
        afterimages = [];
        for (let i = 0; i < prevPositions.length; i += AFTERIMAGE_SPACING) {
          const idx = prevPositions.length-1-i;
          if (idx < 0) break;
          const life = 1.0 - (i/(AFTERIMAGE_COUNT*AFTERIMAGE_SPACING));
          if (life > 0) afterimages.push({ x: prevPositions[idx].x, y: prevPositions[idx].y, angle: prevPositions[idx].angle, speed: prevPositions[idx].speed, life: life*0.7 });
        }
      }

      function drawSpeedLines(wx, wy, speed) {
        if (speed < SPEED_LINE_THRESHOLD) return;
        const sp = worldToScreen(wx, wy);
        const count = Math.floor(SPEED_LINE_COUNT * Math.min(speed/3000, 1));
        const sn = speed || 1;
        const vxn = -vx/sn, vyn = -vy/sn;
        ctx.save();
        ctx.strokeStyle = 'rgba(255,255,255,0.4)';
        ctx.lineWidth = 1.2 * camera.zoom;
        ctx.lineCap = 'round';
        for (let i = 0; i < count; i++) {
          const ao = (Math.random()-0.5)*Math.PI*0.7;
          const c = Math.cos(ao), s = Math.sin(ao);
          const dx = vxn*c - vyn*s, dy = vxn*s + vyn*c;
          const sd = (RADIUS+Math.random()*8)*camera.zoom;
          const len = SPEED_LINE_LENGTH*(0.5+Math.random()*0.5)*Math.min(speed/2000,1)*camera.zoom;
          ctx.globalAlpha = 0.15+Math.random()*0.4;
          ctx.beginPath();
          ctx.moveTo(sp.x+dx*sd, sp.y+dy*sd);
          ctx.lineTo(sp.x+dx*(sd+len), sp.y+dy*(sd+len));
          ctx.stroke();
        }
        ctx.restore();
      }

      function updatePhysics(dt) {
        const maxDt = 0.05;
        const stepDt = Math.min(dt, maxDt);
        vy += GRAVITY * stepDt;
        cx += vx * stepDt;
        cy += vy * stepDt;
        const w = WORLD_W, h = WORLD_H;
        if (cx < -RADIUS) cx += w;
        if (cx > w + RADIUS) cx -= w;
        if (cy - RADIUS < 0) { cy = RADIUS; vy = -vy*BOUNCE_DAMP; angularVelocity += vx/RADIUS*0.3; }
        const onGround = (cy + RADIUS >= h - 0.5);
        if (cy + RADIUS > h) {
          cy = h - RADIUS;
          vy = -vy*BOUNCE_DAMP;
          angularVelocity += (vx - angularVelocity*RADIUS)/RADIUS*0.4;
          if (Math.abs(vy) < 60) vx *= GROUND_FRICTION;
        }
        if (onGround && Math.abs(vy) < 60) {
          const target = vx/RADIUS;
          angularVelocity += (target-angularVelocity)*ROLLING_TORQUE*stepDt;
          angularVelocity *= Math.pow(GROUND_SPIN_FRICTION, stepDt*60);
          vx += (target-angularVelocity)*RADIUS*ROLLING_TORQUE*stepDt*0.5;
        } else {
          angularVelocity *= Math.pow(SPIN_FRICTION, stepDt*60);
        }
        angle += angularVelocity * stepDt;
        if (Math.abs(vx) < 0.1) vx = 0;
        if (Math.abs(vy) < 0.1) vy = 0;
        if (Math.abs(angularVelocity) < 0.01) angularVelocity = 0;
        if (!dragging) updateAfterimages();
      }

      function addToVelocityBuffer(vxS, vyS) {
        velocityBuffer.push({ vx: vxS, vy: vyS, time: performance.now() });
        const cutoff = performance.now()-150;
        velocityBuffer = velocityBuffer.filter(s => s.time > cutoff);
        if (velocityBuffer.length > LATENCY_BUFFER_SIZE) velocityBuffer.shift();
      }

      function getBestVelocity() {
        const cutoff = performance.now()-150;
        velocityBuffer = velocityBuffer.filter(s => s.time > cutoff);
        if (velocityBuffer.length === 0) return { vx:0, vy:0 };
        let best = velocityBuffer[0];
        let bestSpd = Math.sqrt(best.vx*best.vx+best.vy*best.vy);
        for (let i=1; i<velocityBuffer.length; i++) {
          const spd = Math.sqrt(velocityBuffer[i].vx*velocityBuffer[i].vx+velocityBuffer[i].vy*velocityBuffer[i].vy);
          if (spd > bestSpd) { bestSpd = spd; best = velocityBuffer[i]; }
        }
        return { vx: best.vx*THROW_SCALE, vy: best.vy*THROW_SCALE };
      }

      function drawBallAtWorld(wx, wy, ang, speed, alpha) {
        const sp = worldToScreen(wx, wy);
        const color = getSpeedColor(speed||0);
        ctx.save();
        ctx.translate(sp.x, sp.y);
        ctx.scale(camera.zoom, camera.zoom);
        ctx.rotate(ang);
        ctx.globalAlpha = alpha;
        ctx.beginPath();
        ctx.arc(0,0,RADIUS,Math.PI/2,Math.PI*1.5);
        ctx.fillStyle = color; ctx.fill();
        ctx.beginPath();
        ctx.arc(0,0,RADIUS,-Math.PI/2,Math.PI/2);
        ctx.fillStyle = '#ffffff'; ctx.fill();
        ctx.beginPath();
        ctx.moveTo(0,-RADIUS); ctx.lineTo(0,RADIUS);
        ctx.strokeStyle = 'rgba(255,255,255,0.3)'; ctx.lineWidth = 0.5; ctx.stroke();
        ctx.beginPath();
        ctx.arc(0,0,RADIUS,0,Math.PI*2);
        ctx.strokeStyle = 'rgba(255,255,255,0.7)'; ctx.lineWidth = 1.5; ctx.stroke();
        ctx.restore();
      }

      function drawMinimap() {
        const mw = minimapCanvas.width, mh = minimapCanvas.height;
        minimapCtx.clearRect(0,0,mw,mh);
        minimapCtx.fillStyle = 'rgba(30,30,30,0.8)';
        minimapCtx.fillRect(0,0,mw,mh);
        const px = (0/WORLD_W)*mw, pw = (PORTAL_WIDTH/WORLD_W)*mw;
        minimapCtx.fillStyle = 'rgba(50,50,50,0.6)';
        minimapCtx.fillRect(0,0,pw,mh);
        minimapCtx.fillRect(mw-pw,0,pw,mh);
        let bx = (cx/WORLD_W)*mw, by = (cy/WORLD_H)*mh;
        minimapCtx.fillStyle = '#fff';
        minimapCtx.beginPath();
        minimapCtx.arc(bx,by,2,0,Math.PI*2);
        minimapCtx.fill();
        const vpW = (canvas.width/camera.zoom)/WORLD_W*mw;
        const vpH = (canvas.height/camera.zoom)/WORLD_H*mh;
        const vpX = (visualCamX/WORLD_W)*mw - vpW/2;
        const vpY = (camera.y/WORLD_H)*mh - vpH/2;
        minimapCtx.strokeStyle = 'rgba(255,255,255,0.5)';
        minimapCtx.lineWidth = 1;
        minimapCtx.strokeRect(vpX,vpY,vpW,vpH);
      }

      function drawGrid() {
        const visibleLeft = visualCamX - (canvas.width/2)/camera.zoom - RADIUS*2;
        const visibleRight = visualCamX + (canvas.width/2)/camera.zoom + RADIUS*2;
        const visibleTop = camera.y - (canvas.height/2)/camera.zoom - RADIUS*2;
        const visibleBottom = camera.y + (canvas.height/2)/camera.zoom + RADIUS*2;

        ctx.strokeStyle = 'rgba(255,255,255,0.03)';
        ctx.lineWidth = 1;
        const GRID = 160;
        
        let startGX = Math.floor(visibleLeft/GRID)*GRID;
        for (let gx = startGX; gx <= visibleRight + WORLD_W; gx += GRID) {
          const sp = worldToScreen(gx % WORLD_W, 0);
          const ep = worldToScreen(gx % WORLD_W, WORLD_H);
          ctx.beginPath();
          ctx.moveTo(sp.x, sp.y);
          ctx.lineTo(ep.x, ep.y);
          ctx.stroke();
        }
        
        let startGY = Math.floor(visibleTop/GRID)*GRID;
        for (let gy = startGY; gy <= visibleBottom; gy += GRID) {
          const sp = worldToScreen(0, gy);
          const ep = worldToScreen(WORLD_W, gy);
          ctx.beginPath();
          ctx.moveTo(sp.x, sp.y);
          ctx.lineTo(ep.x, ep.y);
          ctx.stroke();
        }

        const bTop = worldToScreen(0, 0);
        const bBot = worldToScreen(0, WORLD_H);
        ctx.strokeStyle = 'rgba(255,255,255,0.2)';
        ctx.lineWidth = 2;
        ctx.beginPath();
        ctx.moveTo(0, bTop.y);
        ctx.lineTo(canvas.width, bTop.y);
        ctx.stroke();
        ctx.beginPath();
        ctx.moveTo(0, bBot.y);
        ctx.lineTo(canvas.width, bBot.y);
        ctx.stroke();
      }

      function drawCircle() {
        const w = canvas.width, h = canvas.height;
        const speed = Math.sqrt(vx*vx+vy*vy);
        ctx.clearRect(0,0,w,h);
        drawGrid();

        const pzL = worldToScreen(0, 0);
        const pzW = PORTAL_WIDTH * camera.zoom;
        ctx.fillStyle = 'rgba(50,50,50,0.4)';
        ctx.fillRect(pzL.x, pzL.y, pzW, h);
        const pzR = worldToScreen(WORLD_W - PORTAL_WIDTH, 0);
        ctx.fillRect(pzR.x, pzR.y, pzW, h);

        for (const img of afterimages) {
          drawBallAtWorld(img.x, img.y, img.angle, img.speed, img.life*0.4);
          const r = RADIUS;
          if (img.x - r < 0 || img.x + r > WORLD_W) {
            drawBallAtWorld(img.x < r ? img.x+WORLD_W : img.x-WORLD_W, img.y, img.angle, img.speed, img.life*0.4);
          }
        }

        if (!dragging) {
          drawSpeedLines(cx, cy, speed);
          const r = RADIUS;
          if (cx - r < 0) drawSpeedLines(cx+WORLD_W, cy, speed);
          if (cx + r > WORLD_W) drawSpeedLines(cx-WORLD_W, cy, speed);
        }

        drawBallAtWorld(cx, cy, angle, speed, 1.0);
        const r = RADIUS;
        if (cx - r < 0) drawBallAtWorld(cx+WORLD_W, cy, angle, speed, 1.0);
        if (cx + r > WORLD_W) drawBallAtWorld(cx-WORLD_W, cy, angle, speed, 1.0);

        drawMinimap();
      }

      function tick(ts) {
        if (lastTimestamp === 0) { lastTimestamp = ts; animationId = requestAnimationFrame(tick); drawCircle(); return; }
        const dt = (ts - lastTimestamp)/1000;
        if (dt > 0.001 && !dragging && !panning) updatePhysics(dt);
        updateCamera();
        const speed = Math.sqrt(vx*vx+vy*vy);
        updateSpeedometer(dragging ? 0 : speed);
        drawCircle();
        lastTimestamp = ts;
        animationId = requestAnimationFrame(tick);
      }

      function getEventPos(e) {
        const rect = canvas.getBoundingClientRect();
        let cx, cy;
        if (e.touches) { if (e.touches.length===0) return null; cx=e.touches[0].clientX; cy=e.touches[0].clientY; }
        else { cx=e.clientX; cy=e.clientY; }
        return { x: cx-rect.left, y: cy-rect.top };
      }

      function isInsideCircle(worldPos) {
        if (!worldPos) return false;
        const w = WORLD_W;
        const hr = RADIUS + 15/camera.zoom;
        let dx = worldPos.x - cx, dy = worldPos.y - cy;
        if (dx*dx+dy*dy <= hr*hr) return true;
        dx = worldPos.x - (cx+w);
        if (dx*dx+dy*dy <= hr*hr) return true;
        dx = worldPos.x - (cx-w);
        if (dx*dx+dy*dy <= hr*hr) return true;
        return false;
      }

      function onPointerDown(e) {
        e.preventDefault();
        const pos = getEventPos(e);
        if (!pos) return;
        const worldPos = screenToWorld(pos.x, pos.y);
        if (isInsideCircle(worldPos)) {
          dragging = true; panning = false;
          dragStartX = worldPos.x; dragStartY = worldPos.y;
          circleStartX = cx; circleStartY = cy;
          prevX = worldPos.x; prevY = worldPos.y;
          prevTime = performance.now();
          vx=0; vy=0; angularVelocity=0; velocityBuffer=[]; afterimages=[]; prevPositions=[];
          canvas.setPointerCapture(e.pointerId||1);
          canvas.style.cursor = 'grabbing';
        } else {
          panning = true; dragging = false;
          panStartX = pos.x; panStartY = pos.y;
          camStartX = visualCamX; camStartY = camera.y;
          canvas.setPointerCapture(e.pointerId||1);
          canvas.style.cursor = 'grab';
        }
      }

      function onPointerMove(e) {
        e.preventDefault();
        if (e.touches && e.touches.length === 2) {
          pinching = true;
          if (dragging) { dragging = false; canvas.style.cursor = 'default'; }
          const t1={x:e.touches[0].clientX,y:e.touches[0].clientY}, t2={x:e.touches[1].clientX,y:e.touches[1].clientY};
          const dist = Math.hypot(t2.x-t1.x, t2.y-t1.y);
          if (pinchStartDist===0) { pinchStartDist=dist; pinchStartZoom=camera.targetZoom; }
          else camera.targetZoom = Math.min(camera.maxZoom, Math.max(camera.minZoom, pinchStartZoom*(dist/pinchStartDist)));
          return;
        }
        pinching=false; pinchStartDist=0;
        if (dragging) {
          const pos = getEventPos(e); if (!pos) return;
          const worldPos = screenToWorld(pos.x, pos.y);
          const now = performance.now(), dt = (now-prevTime)/1000;
          if (dt > 0.001) { addToVelocityBuffer((worldPos.x-prevX)/dt, (worldPos.y-prevY)/dt); }
          cx = circleStartX + (worldPos.x - dragStartX);
          cy = circleStartY + (worldPos.y - dragStartY);
          cx = wrapX(cx); cy = clampCircleY(cy);
          prevX = worldPos.x; prevY = worldPos.y; prevTime = now;
        } else if (panning) {
          const pos = getEventPos(e); if (!pos) return;
          visualCamX = camStartX - (pos.x - panStartX)/camera.zoom;
          camera.y = camStartY - (pos.y - panStartY)/camera.zoom;
          while (visualCamX < 0) visualCamX += WORLD_W;
          while (visualCamX > WORLD_W) visualCamX -= WORLD_W;
          camera.x = visualCamX;
        }
      }

      function onPointerUp(e) {
        e.preventDefault();
        if (dragging) {
          dragging = false; canvas.style.cursor = 'default';
          canvas.releasePointerCapture(e.pointerId||1);
          const bestVel = getBestVelocity();
          vx=bestVel.vx; vy=bestVel.vy; angularVelocity=vx/RADIUS;
          velocityBuffer=[]; cx=wrapX(cx); cy=clampCircleY(cy);
        }
        if (panning) { panning=false; canvas.style.cursor='default'; canvas.releasePointerCapture(e.pointerId||1); }
        pinching=false; pinchStartDist=0;
      }

      function onWheel(e) {
        e.preventDefault();
        camera.targetZoom = Math.min(camera.maxZoom, Math.max(camera.minZoom, camera.targetZoom + (-e.deltaY*0.001)*camera.targetZoom));
      }

      function bindEvents() {
        canvas.addEventListener('pointerdown', onPointerDown);
        canvas.addEventListener('pointermove', onPointerMove);
        canvas.addEventListener('pointerup', onPointerUp);
        canvas.addEventListener('pointercancel', onPointerUp);
        canvas.addEventListener('wheel', onWheel, { passive: false });
        canvas.addEventListener('contextmenu', e => e.preventDefault());
        canvas.addEventListener('touchstart', e => e.preventDefault(), { passive: false });
        canvas.addEventListener('touchmove', e => e.preventDefault(), { passive: false });
        canvas.addEventListener('touchend', e => e.preventDefault());
        canvas.addEventListener('touchcancel', e => e.preventDefault());
        window.addEventListener('resize', resizeCanvas);
      }

      function init() {
        resizeCanvas();
        cx = WORLD_W/2; cy = WORLD_H/2;
        visualCamX = cx; camera.x = cx; camera.y = cy;
        bindEvents();
        animationId = requestAnimationFrame(tick);
      }

      init();
    })();
  </script>
</body>
</html>
